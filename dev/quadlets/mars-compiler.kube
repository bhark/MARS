[Unit]
Description=MARS local compiler
Requires=mars-seed.service
After=mars-seed.service

[Kube]
Yaml=%h/.local/share/mars-dev/manifests/compiler.yaml
Network=mars.network
# pre-load mars-config ConfigMap; podman kube play does not persist
# ConfigMaps across plays the way it does Secrets.
ConfigMap=%h/.local/share/mars-dev/manifests/mars-config-cm.yaml

[Service]
Restart=on-failure

[Install]
WantedBy=default.target
