# MarsService variant that exercises operator-driven postgres bootstrap.
# The fixture-loader-no-replication Job restores the OSM dump and derives
# e2e_source.* but does NOT create the publication or slot - the bootstrap
# Job rendered by the operator does that.
---
apiVersion: v1
kind: Secret
metadata:
  name: mars-bootstrap-admin
type: Opaque
stringData:
  # admin connects as the superuser created by postgis bootstrap.
  dsn: "postgres://mars:mars@postgis:5432/mars?sslmode=disable"
---
apiVersion: v1
kind: Secret
metadata:
  name: mars-bootstrap-runtime
type: Opaque
stringData:
  password: "replicator-password"
---
apiVersion: mars.forn.dk/v1alpha1
kind: MarsService
metadata:
  name: mars-bs
spec:
  bootstrap:
    enabled: true
    adminSecretRef:
      name: mars-bootstrap-admin
      key: dsn
    runtimePasswordSecretRef:
      name: mars-bootstrap-runtime
      key: password
    teardownOnDelete:
      slot: true
      publication: true
      role: false
  compiler:
    resources:
      requests: { cpu: "100m", memory: "256Mi" }
      limits:   { cpu: "1",    memory: "1Gi" }
    storage:
      cacheSize: 512Mi
      workSize: 1Gi
    imagesConfigMap: mars-images
    env:
      - { name: AWS_REGION, value: us-east-1 }
      - { name: AWS_EC2_METADATA_DISABLED, value: "true" }
      # runtime/compiler talk to the postgis as the bootstrapped role.
      - { name: PG_DSN, value: "postgres://mars_replicator:replicator-password@postgis:5432/mars" }
    envFrom:
      - secretRef:
          name: mars-s3-credentials
  runtime:
    replicas: 1
    resources:
      requests: { cpu: "100m", memory: "256Mi" }
      limits:   { cpu: "1",    memory: "1Gi" }
    cache:
      sizeLimit: 256Mi
    service:
      serviceType: ClusterIP
      port: 8080
    env:
      - { name: AWS_REGION, value: us-east-1 }
      - { name: AWS_EC2_METADATA_DISABLED, value: "true" }
      - { name: PG_DSN, value: "postgres://mars_replicator:replicator-password@postgis:5432/mars" }
    envFrom:
      - secretRef:
          name: mars-s3-credentials
  config:
    service:
      name: mars-bs
      title: "MARS bootstrap e2e"
      contact_email: ops@example.org
    source:
      type: postgis
      dsn: "${PG_DSN}"
      native_crs: EPSG:25832
      change_feed:
        type: pgoutput
        publication: mars_bs_pub
        slot: mars_bs_slot
      bootstrap:
        role: mars_replicator
        schemas:
          - e2e_source
      pool:
        max_size: 4
        statement_timeout_ms: 300000
        batch_send_timeout_secs: 30
    artifacts:
      store:
        type: s3
        endpoint: "http://seaweedfs:8333"
        region: us-east-1
        bucket: mars-artifacts
        prefix: bs
        allow_http: true
        conditional_put: disabled
        allow_non_atomic_publish: true
      cache:
        path: /cache
        max_size: 256MiB
        eviction: lru
    compiler:
      compile_binding_parallelism: 2
      compile_in_flight_pages_budget_bytes: 256MiB
      compile_spill_dir: /work/spill
      images_dir: /var/lib/mars/images
    scales:
      bands:
        - { name: lo, max_denom_exclusive: 10000000 }
    cells:
      grid: regular
      origin: [0, 0]
      size_per_band:
        lo: 32768m
    interfaces:
      wms:  { enabled: true }
    reprojection:
      allowlist: [EPSG:25832]
    styles:
      poly_land: { type: polygon, fill: "#ffffff" }
    layers:
      - name: land
        title: "Land"
        type: polygon
        sources:
          - { band: lo, from: e2e_source.land, geometry_column: geom, id_column: id }
        classes:
          - { name: default, title: "Land", style: { type: ref, name: poly_land } }
    observability:
      log_level: info
      log_format: json
