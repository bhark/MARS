# single-replica postgis for the test namespace. wal_level=logical so the
# compiler's pgoutput change-feed works. ephemeral; tests don't outlive ns.
---
apiVersion: v1
kind: Secret
metadata:
  name: postgis-credentials
type: Opaque
stringData:
  POSTGRES_USER: mars
  POSTGRES_PASSWORD: mars
  POSTGRES_DB: mars
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: postgis-init
data:
  00-init.sql: |
    -- ensure PostGIS is installed in template1 so subsequent DBs inherit it.
    \c template1
    CREATE EXTENSION IF NOT EXISTS postgis;
    \c mars
    CREATE EXTENSION IF NOT EXISTS postgis;
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgis
  labels:
    app: postgis
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: postgis
  template:
    metadata:
      labels:
        app: postgis
    spec:
      containers:
        - name: postgis
          image: postgis/postgis:18-3.6
          args:
            - postgres
            - -c
            - wal_level=logical
            - -c
            - max_replication_slots=8
            - -c
            - max_wal_senders=8
          envFrom:
            - secretRef:
                name: postgis-credentials
          ports:
            - { name: pg, containerPort: 5432 }
          readinessProbe:
            exec:
              command: ["pg_isready", "-U", "mars", "-d", "mars"]
            initialDelaySeconds: 5
            periodSeconds: 3
          volumeMounts:
            - { name: data, mountPath: /var/lib/postgresql }
            - { name: init, mountPath: /docker-entrypoint-initdb.d }
      volumes:
        - name: data
          emptyDir: {}
        - name: init
          configMap:
            name: postgis-init
---
apiVersion: v1
kind: Service
metadata:
  name: postgis
spec:
  selector:
    app: postgis
  ports:
    - { name: pg, port: 5432, targetPort: 5432 }
