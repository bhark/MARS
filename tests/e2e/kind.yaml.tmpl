kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: mars-e2e
nodes:
  - role: control-plane
    # extra mount so the test driver can stage the fixture dump into the
    # cluster without going through a ConfigMap (sql.gz easily exceeds 1MiB).
    # hostPath must be absolute: kind resolves relative paths against the
    # invoker's cwd, not the config file, so a relative path breaks the moment
    # the script is run from a different directory. run-e2e.sh renders this
    # template with the repo root inlined.
    extraMounts:
      - hostPath: {{REPO_ROOT}}/target/e2e-fixtures
        containerPath: /var/lib/mars-e2e-fixtures
