[Unit]
Description=MARS e2e runtime
Requires=mars-e2e-compiler.service
After=mars-e2e-compiler.service

[Kube]
Yaml=%h/.local/share/mars-e2e/manifests/runtime.yaml
Network=mars-e2e.network
ConfigMap=%h/.local/share/mars-e2e/manifests/mars-config-cm.yaml

[Service]
Restart=on-failure

[Install]
WantedBy=default.target
