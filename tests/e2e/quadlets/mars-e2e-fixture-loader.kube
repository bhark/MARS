[Unit]
Description=MARS e2e fixture loader
Requires=mars-e2e-postgis.service
After=mars-e2e-postgis.service

[Kube]
Yaml=%h/.local/share/mars-e2e/manifests/fixture-loader.yaml
Network=mars-e2e.network
ExitCodePropagation=all

[Service]
Type=oneshot
RemainAfterExit=yes

[Install]
WantedBy=default.target
