[Unit]
Description=MARS e2e compiler
Requires=mars-e2e-fixture-loader.service
After=mars-e2e-fixture-loader.service

[Kube]
Yaml=%h/.local/share/mars-e2e/manifests/compiler.yaml
Network=mars-e2e.network
# pre-load mars-config ConfigMap; podman kube play does not persist
# ConfigMaps across plays the way it does Secrets.
ConfigMap=%h/.local/share/mars-e2e/manifests/mars-config-cm.yaml

[Service]
Restart=on-failure

[Install]
WantedBy=default.target
